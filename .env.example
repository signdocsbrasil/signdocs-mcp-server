# SignDocs Brasil API credentials (OAuth2 client_credentials).
# Get these from the SignDocs dashboard (app.signdocs.com.br → API).
SIGNDOCS_CLIENT_ID=
SIGNDOCS_CLIENT_SECRET=

# Which API environment to talk to: "hml" (homologação/staging, default) or "production".
SIGNDOCS_ENVIRONMENT=hml

# Optional: override the resolved base URL entirely (e.g. for local testing).
# SIGNDOCS_BASE_URL=https://api-hml.signdocs.com.br

# Optional: space-separated OAuth scopes to request. Defaults to the full
# read/write set. The token endpoint filters these against what your
# credential is actually authorized for, so requesting extra is harmless.
# SIGNDOCS_SCOPES=transactions:read transactions:write steps:write evidence:read webhooks:write verification:write
