{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "br.com.signdocs/mcp-server",
  "description": "SignDocs Brasil e-signature tools for AI agents — signing sessions, envelopes, verification.",
  "version": "0.3.2",
  "websiteUrl": "https://www.signdocs.com.br/integracao-claude-ia-mcp.html",
  "repository": {
    "url": "https://github.com/signdocsbrasil/signdocs-mcp-server",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@signdocs-brasil/mcp-server",
      "version": "0.3.2",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "SIGNDOCS_CLIENT_ID", "description": "OAuth2 client ID from app.signdocs.com.br → API", "isRequired": true, "isSecret": false },
        { "name": "SIGNDOCS_CLIENT_SECRET", "description": "OAuth2 client secret from app.signdocs.com.br → API", "isRequired": true, "isSecret": true },
        { "name": "SIGNDOCS_ENVIRONMENT", "description": "Target environment: hml (sandbox) or production", "isRequired": false, "isSecret": false }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.signdocs.com.br/mcp",
      "headers": [
        { "name": "X-SignDocs-Client-Id", "description": "OAuth2 client ID", "isRequired": true, "isSecret": false },
        { "name": "X-SignDocs-Client-Secret", "description": "OAuth2 client secret", "isRequired": true, "isSecret": true }
      ]
    }
  ]
}
